{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "src/agentops/__main__.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "preLaunchTask": "uv_sync",
            // For DevContainer (linux), use the following line:
            //"python": "/home/vscode/.venv/bin/python"
            // For Windows Platform, uncomment the following line:
            "python": ".venv/Scripts/python",
        }
    ]
